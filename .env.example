# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sat_platform?schema=public"

# NextAuth / Auth.js v5
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Desmos API key (optional — public demo key works for development)
NEXT_PUBLIC_DESMOS_API_KEY="dcb31709b452b1cf9dc26972add0fda6"

# Image uploads — Cloudinary. Get these from your Cloudinary dashboard.
# The cloud name + API key are safe in client builds; the secret is server-only.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
